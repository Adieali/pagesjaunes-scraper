# ─────────────────────────────────────────────────────────────
# Pages Jaunes Pro Scraper — Configuration
# Copiez ce fichier en .env et ajustez les valeurs
# ─────────────────────────────────────────────────────────────

# ── Proxies ───────────────────────────────────────────────────
# Liste de proxies séparés par des virgules
# Formats supportés : http://, https://, socks5://
PROXIES=
PROXY_ENABLED=false

# ── Throttling ────────────────────────────────────────────────
DOWNLOAD_DELAY=2.0

# ── Scrapy par défaut ─────────────────────────────────────────
SCRAPY_SETTINGS_MODULE=pagesjaunes.settings
